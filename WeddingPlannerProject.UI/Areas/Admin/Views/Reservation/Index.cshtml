@model IEnumerable<WeddingPlannerProject.Model.Reservation>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="fw-bold mb-4">Rezervasyonlar</h2>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>Telefon</th>
                    <th>Paket</th>
                    <th>Düğün Tarihi</th>
                    <th>Not</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.Phone</td>
                        <td>@item.ProductPackage.Name</td>
                        <td>@item.WeddingDate.ToShortDateString()</td>
                        <td>@item.Note</td>
                        <td>
                            @if (item.IsConfirmed)
                            {
                                <span class="badge bg-success">Onaylandı</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Bekliyor</span>
                            }
                        </td>

                        <td class="text-end">
                            @if (!item.IsConfirmed)
                            {
                                <a href="/Admin/Reservation/Confirm/@item.Id" class="btn btn-sm btn-success">
                                    Onayla
                                </a>
                            }

                            <a href="/Admin/Reservation/Delete/@item.Id" class="btn btn-sm btn-outline-danger">
                                Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>