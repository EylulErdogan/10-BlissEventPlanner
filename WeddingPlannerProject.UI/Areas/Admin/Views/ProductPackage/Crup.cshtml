@model WeddingPlannerProject.UI.Models.ViewModels.ProductPackageViewModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <h2 class="fw-bold">Ürün / Paket @(Model.ProductPackage.Id <= 0 ? "Ekle" : "Güncelle")</h2>
    <p class="text-muted">Ürün veya paket bilgilerini doldurun.</p>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">

        <form method="post" enctype="multipart/form-data">

            <input asp-for="ProductPackage.Id" type="hidden" />
            <input asp-for="ProductPackage.ImageUrl" type="hidden" />

            @if (!string.IsNullOrEmpty(Model.ProductPackage.ImageUrl))
            {
                <div class="mb-3">
                    <label class="form-label">Mevcut Resim</label><br />
                    <img src="@Model.ProductPackage.ImageUrl" width="220" height="150" style="object-fit:cover;" class="rounded shadow-sm" />
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Kategori</label>
                <select asp-for="ProductPackage.CategoryId" asp-items="@Model.CategoryList" class="form-control">
                    <option disabled selected>-- Kategori Seçiniz --</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Ad</label>
                <input asp-for="ProductPackage.Name" class="form-control" placeholder="Örn: Gold Düğün Paketi" />
            </div>

            <div class="mb-3">
                <label class="form-label">Açıklama</label>
                <textarea asp-for="ProductPackage.Description" class="form-control" rows="4" placeholder="Paket içeriğini yazınız"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Fiyat</label>
                <input asp-for="ProductPackage.Price" class="form-control" placeholder="Örn: 25000" />
            </div>

            <div class="mb-3">
                <label class="form-label">Tür</label>
                <select asp-for="ProductPackage.IsPackage" class="form-control">
                    <option value="false">Ürün</option>
                    <option value="true">Paket</option>
                </select>
            </div>

            <div class="form-check mb-3">
                <input asp-for="ProductPackage.IsActive" class="form-check-input" />
                <label class="form-check-label">Aktif olarak göster</label>
            </div>
            <div class="form-check mb-3">
                <input asp-for="ProductPackage.IsPopular" class="form-check-input" />
                <label asp-for="ProductPackage.IsPopular" class="form-check-label">
                    Popüler olarak göster
                </label>
            </div>

            <div class="mb-3">
                <label class="form-label">Resim Seç</label>
                <input type="file" name="file" accept="image/*" class="form-control" />
            </div>

            <button type="submit" class="btn btn-dark">
                @(Model.ProductPackage.Id <= 0 ? "Kaydet" : "Güncelle")
            </button>

            <a href="/Admin/ProductPackage/Index" class="btn btn-secondary">
                Geri Dön
            </a>

        </form>

    </div>
</div>