@model IEnumerable<WeddingPlannerProject.Model.Sale>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="fw-bold mb-4">Satışlar</h2>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Paket / Ürün</th>
                    <th>Toplam Fiyat</th>
                    <th>Satış Tarihi</th>
                    <th>Kullanıcı Id</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProductPackage.Name</td>
                        <td>@item.TotalPrice ₺</td>
                        <td>@item.SaleDate.ToShortDateString()</td>
                        <td>@item.UserId</td>

                        <td class="text-end">
                            <a href="/Admin/Sale/Delete/@item.Id" class="btn btn-sm btn-outline-danger">
                                Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>