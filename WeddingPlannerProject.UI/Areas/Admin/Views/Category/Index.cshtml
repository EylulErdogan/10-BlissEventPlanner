@model IEnumerable<WeddingPlannerProject.Model.Category>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold">Kategoriler</h2>
        <p class="text-muted">Düğün planlama kategorilerini yönetin.</p>
    </div>

    <a href="/Admin/Category/Crup" class="btn btn-dark">
        <i class="bi bi-plus-circle"></i> Yeni Kategori
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Kategori Adı</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.CategoryName</td>
                        <td class="text-end">
                            <a href="/Admin/Category/Crup/@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Güncelle
                            </a>

                            <a href="/Admin/Category/Delete/@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>