@model WeddingPlannerProject.Model.Category

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <h2 class="fw-bold">Kategori @(Model.Id <= 0 ? "Ekle" : "Güncelle")</h2>
    <p class="text-muted">Kategori bilgilerini doldurun.</p>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post">
            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label class="form-label">Kategori Adı</label>
                <input asp-for="CategoryName" class="form-control" placeholder="Örn: Kına, Nişan, Düğün" />
            </div>

            <button type="submit" class="btn btn-dark">
                @(Model.Id <= 0 ? "Kaydet" : "Güncelle")
            </button>

            <a href="/Admin/Category/Index" class="btn btn-secondary">
                Geri Dön
            </a>
        </form>
    </div>
</div>