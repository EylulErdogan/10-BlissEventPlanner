@model IEnumerable<WeddingPlannerProject.Model.ContactRequest>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="fw-bold mb-4">Aranma Talepleri</h2>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>Telefon</th>
                    <th>Talep Tarihi</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.Phone</td>
                        <td>@item.RequestDate.ToShortDateString()</td>
                        <td>
                            @if (item.IsCalled)
                            {
                                <span class="badge bg-success">Arandı</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Bekliyor</span>
                            }
                        </td>

                        <td class="text-end">
                            @if (!item.IsCalled)
                            {
                                <a href="/Admin/ContactRequest/MarkAsCalled/@item.Id" class="btn btn-sm btn-success">
                                    Arandı Yap
                                </a>
                            }

                            <a href="/Admin/ContactRequest/Delete/@item.Id" class="btn btn-sm btn-outline-danger">
                                Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>