        </div>

        <div class="entry-item col-md-4 my-3">
          <a href="images/post-1.jpg" title="photo" class="image-link"><img src="~/images/post-1.jpg"
              class=" post-image img-fluid  "></a>
        </div>

      </div>
      <!-- <div class="text-center">
        <a class="btn btn-primary mt-5" href="gallery.html">View Gallery</a>
      </div> -->
    </div>
  </section>

  <section id="price" class="overflow-hidden">
    <div class="container padding-medium">
      <h6 class="fw-normal text-center text-primary">Grab it now!</h6>
      <h2 class="display-4 fw-normal text-center mb-4">Pricing Plans</h2>
      <div class="row g-lg-5">
          @foreach (var item in Model.Where(x => x.IsPackage))
