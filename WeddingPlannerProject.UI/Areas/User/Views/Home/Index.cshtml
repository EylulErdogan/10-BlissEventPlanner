@model IEnumerable<WeddingPlannerProject.Model.ProductPackage>
@{
    Layout = "_UserLayout";
}

  <section id="slider" class="overflow-hidden">
    <div class="container-lg">
      <div class="row flex-row-reverse align-items-center">
        <div class="col-md-8" data-aos="fade-up">
          <div class="swiper slider">
            <div class="swiper-wrapper">
              <div class="swiper-slide ">
                <div>
                  <img src="~/images/banner-img1.jpg" class="img-fluid" alt="banner-img1">
                </div>
              </div>
              <div class="swiper-slide ">
                <div>
                  <img src="~/images/banner-img2.jpg" class="img-fluid" alt="banner-img1">
                </div>
              </div>
              <div class="swiper-slide ">
                <div>
                  <img src="~/images/banner-img3.jpg" class="img-fluid" alt="banner-img1">
                </div>
              </div>
              <div class="swiper-slide ">
                <div>
                  <img src="~/images/banner-img4.jpg" class="img-fluid" alt="banner-img1">
                </div>
              </div>
              <div class="swiper-slide ">
                <div>
                  <img src="~/images/banner-img5.jpg" class="img-fluid" alt="banner-img1">
                </div>
              </div>
              <div class="swiper-slide ">
                <div>
                  <img src="~/images/banner-img6.jpg" class="img-fluid" alt="banner-img1">
                </div>
              </div>

            </div>
            <div class="position-absolute top-0 bottom-0 end-0 m-auto me-0 me-md-5 main-slider-button-next">
              <svg class="arrow-right light-color" width="60" height="60">
                <use xlink:href="#arrow-right"></use>
              </svg>
            </div>
            <div class="position-absolute top-0 bottom-0 start-0 m-auto ms-0 ms-md-5 main-slider-button-prev">
              <svg class="arrow-left light-color" width="60" height="60">
                <use xlink:href="#arrow-left"></use>
              </svg>
            </div>
          </div>
        </div>
        <div class="col-md-4 mt-4 mt-md-0" data-aos="fade-up">
          <div class="section-title">
            <h2 class="display-4 fw-normal mb-3 text-capitalize">En Güvenilir ve Zarif Organizasyon
            </h2>
          </div>
          <p>Düğün planlama hizmetlerimizle yaratıcılık, özen ve keyfin mükemmel birleşimini yaşayın. Uzman planlayıcılarımız, samimi törenlerden görkemli resepsiyonlara kadar unutulmaz kutlamalar yaratmaya adanmıştır ve özel gününüzün sizin benzersiz aşk hikayenizi yansıtmasını sağlar.</p>
          <a class="btn btn-primary mt-3" href="about.html">Daha Fazla</a>
        </div>
      </div>
    </div>
  </section>

  <section id="categories" class="overflow-hidden">
    <div class="container-lg padding-medium">
      <div class="row" data-aos="fade-up">
        <div class="col-md-3 my-3">
          <div class="text-center">
            <iconify-icon icon="solar:star-linear" class="service-icon text-primary display-3"></iconify-icon>
            <h3 class="py-2">10+ Yıllık Deneyim</h3>
            <p class="blog-paragraph">Uzmanlık ve tutkuyla rüya gibi düğünler yaratıyoruz. Sizin hayalleriniz, bizim adanmışlığımız.
            </p>
          </div>
        </div>
        <div class="col-md-3 my-3">
          <div class="text-center">
            <iconify-icon class="service-icon text-primary display-3" icon="ph:plant-light"></iconify-icon>
            <h3 class="py-2">Çevre Dostu Seçenekler</h3>
            <p class="blog-paragraph">Yerel kaynaklı çiçeklerle düzenlenen sürdürülebilir düğünler.</p>
          </div>
        </div>
        <div class="col-md-3 my-3">
          <div class="text-center">
            <iconify-icon class="service-icon text-primary display-3"
              icon="solar:chat-square-like-broken"></iconify-icon>
            <h3 class="py-2">5k+ Mutlu Çift</h3>
            <p class="blog-paragraph">Çiftler, kusursuz ve stressiz kutlamalar düzenlemesi konusunda bize güveniyor.</p>
          </div>
        </div>
        <div class="col-md-3 my-3">
          <div class="text-center">
            <iconify-icon class="service-icon text-primary display-3"
              icon="fluent:people-team-28-regular"></iconify-icon>
            <h3 class="py-2">28 Uzman Ekip</h3>
            <p class="blog-paragraph">Tasarım, koordinasyon ve konuk ağırlama alanlarında uzmanlaşmış yetenekli bir ekip.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="position-relative overflow-hidden">
    <div class="position-absolute top-0 end-0 z-n1 d-none d-md-block">
      <img src="~/images/bg-pattern11.png" alt="pattern" class="img-fluid">
    </div>
    <div class="position-absolute bottom-0 z-n1 d-none d-md-block">
      <img src="~/images/bg-pattern1.png" alt="pattern" class="img-fluid">
    </div>
    <div class="container">
      <div class="row align-items-center p-5 g-md-5">
        <div class="col-md-5" data-aos="fade-right">
          <img src="~/images/about-img.jpg" class="img-fluid" alt="image">
        </div>
        <div class="col-md-7 mt-5 mt-md-0" data-aos="fade-left">
          <div class="text-content ps-md-5">
            <h6 class="fw-normal text-primary">Hakkımızda</h6>
            <h3 class="display-5 fw-normal">Hayalinizdeki Düğünü Hazırlayalım</h3>
            <p>Merhaba, ben Eylül; işine kendini adamış bir düğün organizatörü, romantizm tutkunu ve mutlu bir evliliğe sahip bir eşim. Tutkum, düğün hayallerinizi gerçeğe dönüştürmek, benzersiz aşk hikayenizi yansıtan unutulmaz anlar yaratmak ve tüm stresi omuzlarınızdan almak.</p>
            <a href="/User/About" class="btn btn-primary mt-2">Hakkımızda</a>
          </div>
        </div>
      </div>
      <!-- <div class="border border-2 border-primary rounded-2">
      </div> -->
    </div>
  </section>

  <section id="services" class="overflow-hidden">
    <div class="container-lg padding-medium">
      <div class="section-title text-center mb-4">
        <h6 class="fw-normal text-primary">Hizmetlerimiz</h6>
        <h3 class="display-5 fw-normal ">Sunduğumuz Hizmetler</h3>
      </div>
      <div class="row g-lg-5 my-0">
           @foreach (var item in Model.Where(x => !x.IsPackage))
            {  
            <div class="col-md-6 col-lg-3 my-4" data-aos="fade-up" data-aos-duration="1000">
          <div class="card p-3 text-center">
            <a href="services-single.html">
              <div class="zoom-effect">
                <img src="@item.ImageUrl" class="img-fluid" alt="image">
              </div>
            </a>
            <a href="services-single.html" class="hover-color">
              <h4 class="mt-3 mb-2">@item.Name</h4>
            </a>
            <p class="card-text">@item.Description
            </p>
            <div class="text-center">
              <a class="btn btn-outline-primary mb-3 px-3 py-1 fs-6 text-capitalize" href="/User/Home/Detail/@item.Id">Bilgi Al</a>
            </div>
          </div>
        </div>
 }
      </div>
    </div>
  </section>

  <section id="gallery" class="overflow-hidden">
    <div class="container-lg" data-aos="fade-up">
      <h6 class="fw-normal text-center text-primary">Galerimiz</h6>
      <h2 class="display-4 fw-normal text-center mb-4">Düğün Törenlerimiz</h2>
      <div class="row entry-container">
