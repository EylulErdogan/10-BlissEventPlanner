  <section id="testimonial" class="bg-primary position-relative overflow-hidden">
    <div class="position-absolute top-0 end-0 pattern-up-about d-none d-md-block">
      <img src="~/images/bg-pattern2.png" alt="pattern" class="img-fluid">
    </div>
    <div class="position-absolute bottom-0 d-none d-md-block">
      <img src="~/images/bg-pattern2.png" alt="pattern" class="img-fluid">
    </div>
    <div class="container-lg padding-medium" data-aos="fade-up">
      <div class="text-center">
        <svg class="quote text-white-50">
          <use xlink:href="#quote"></use>
        </svg>
      </div>
      <div class="row justify-content-center">
        <div class="col-md-6">
          <div class="swiper testimonial-swiper">
            <div class="swiper-wrapper">
              <div class="swiper-slide">
                <div class="review">
                  <div class="review-content text-center">
                    <p class="text-white fs-3 lh-base">"Emily transformed our wedding vision into reality beyond our
                      expectations! Her attention to detail and creative solutions made our day absolutely perfect. We
                      couldn't have done it without her expertise and calm guidance."</p>
                    <img src="~/images/reviewer1.jpg" alt="reviewer" class="img-fluid rounded-circle">
                    <h5 class="text-white m-0 lh-sm">Sarah & Michael</h5>
                  </div>
                </div>
              </div>
              <div class="swiper-slide">
                <div class="review">
                  <div class="review-content text-center">
                    <p class="text-white fs-3 lh-base">"From the first consultation to our magical send-off, the
                      planning team made everything seamless. They handled every crisis before we even knew about it,
                      allowing us to simply enjoy our special day. Worth every penny!"</p>
                    <img src="~/images/reviewer2.jpg" alt="reviewer" class="img-fluid rounded-circle">
                    <h5 class="text-white m-0 lh-sm">Jessica & David</h5>
                  </div>
                </div>
              </div>
              <div class="swiper-slide">
                <div class="review">
                  <div class="review-content text-center">
                    <p class="text-white fs-3 lh-base">"Our destination wedding was flawless thanks to their
                      coordination. They managed vendors across three countries and created the most romantic atmosphere
                      we could imagine. Every guest said it was the best wedding they'd ever attended!"</p>
                    <img src="~/images/reviewer3.jpg" alt="reviewer" class="img-fluid rounded-circle">
                    <h5 class="text-white m-0 lh-sm">Amanda & James</h5>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    </div>
  </section>


  <section id="inquiry" class="jarallax overflow-hidden"
    style="background-image: url(/images/background-1.jpg); background-repeat: no-repeat; background-position: center;">
    <div class="container-lg padding-medium">
      <div class="col-md-6 text-center" data-aos="fade-right">
        <div class="card p-4">
          <div class="p-4 border border-2 border-primary rounded-2">
            <h2 class="display-4 fw-normal mb-3">Make An Inquiry</h2>
            <p class="">Call: 666 333 9999 or Fill in the form below</p>
            <form class="contact-form row mt-5">
              <div class="form-input col-lg-12 d-md-flex mb-3">
                <input type="text" name="name" placeholder="Write Your Name Here"
                  class="form-control w-100 ps-4 py-3 mb-2 me-3">
                <input type="text" name="email" placeholder="Write Your Email Here"
                  class="form-control w-100 ps-4 py-3 mb-2">
              </div>
              <div class="form-input col-lg-12 d-md-flex mb-3">
                <input type="number" name="phone" placeholder="Contact number"
                  class="form-control w-100 ps-4 py-3 mb-2 me-3">
                <input type="number" name="person" placeholder="No of People"
                  class="form-control w-100 ps-4 py-3 mb-2 ">
              </div>
              <div class="form-input col-lg-12 d-md-flex mb-3">
                <input type="date" name="phone" placeholder="Contact number"
                  class="form-control w-100 ps-4 py-3 mb-2 me-3">
                <input type="time" name="person" placeholder="No of People" class="form-control w-100 ps-4 py-3 mb-2 ">
              </div>
              <div class="col-md-12 col-sm-12 mb-4">
                <textarea type="text" name="message" placeholder="Your message" rows="4"
                  class="form-control w-100 ps-4 py-3 "></textarea>
              </div>
            </form>
            <button class="btn btn-primary mt-3" href="#">Send Now</button>
          </div>
        </div>
      </div>
    </div>
    </div>
  </section>
  @if (TempData["ReservationSuccess"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Rezervasyon Alındı',
            text: 'Rezervasyon talebiniz başarıyla alınmıştır. Admin onayından sonra sizinle iletişime geçilecektir.',
            confirmButtonText: 'Tamam',
            confirmButtonColor: '#c89b6d'
        });
    </script>
}