@{
    Layout = "_UserLayout";
}
<section id="banner" class="position-relative overflow-hidden">
    <div class="position-absolute top-0 end-0 z-n1 d-none d-md-block aos-init aos-animate" data-aos="fade-left">
        <img src="~/images/bg-pattern11.png" alt="pattern" class="img-fluid">
    </div>
    <div class="position-absolute bottom-0 z-n1 d-none d-md-block aos-init aos-animate" data-aos="fade-right">
        <img src="~/images/bg-pattern1.png" alt="pattern" class="img-fluid">
    </div>
    <div class="container-lg padding-medium aos-init aos-animate" data-aos="fade-up">
        <div class="hero-content text-center">
            <h2 class="banner-title display-2">Hakkımızda</h2>
            <nav class="breadcrumb d-flex justify-content-center">
                <a class="breadcrumb-item nav-link banner-title" href="index.html">Ana Sayfa</a>
                <a class="breadcrumb-item nav-link banner-title" href="#">Sayfalar</a>
                <span class="breadcrumb-item banner-title active" aria-current="page">Hakkımızda</span>
            </nav>
        </div>
    </div>
</section>

<div class="container-lg overflow-hidden">
    <div class="row align-items-center">
        <div class="col-md-4 mt-5 aos-init aos-animate" data-aos="fade-right">
            <div>
                <img src="~/images/post-4.jpg" alt="Organizasyon ekibimiz" class="video-image img-fluid">
            </div>
        </div>

        <div class="col-md-4 mt-5 aos-init aos-animate" data-aos="fade-up">
            <h3>Başarı Hikayemiz</h3>
            <p>
                Organizasyon firmamız, çiftlerin en özel anlarını unutulmaz anılara dönüştürme tutkusu ile kuruldu.
                Küçük bir ekip olarak başladığımız bu yolculukta, yaratıcı fikirlerimiz ve detaylara verdiğimiz önem sayesinde
                sektörde güvenilir bir marka haline geldik.
            </p>
            <p>
                Her organizasyonu çiftlerimizin hayallerine göre tasarlıyor, profesyonel ekibimizle tüm süreci
                eksiksiz planlıyoruz. Kaliteli hizmet anlayışımızla her geçen gün daha fazla mutlu çifte ulaşıyoruz.
            </p>

            <p class="m-0 mb-2"><span class="text-primary">✓</span> Deneyimli organizasyon danışmanlarından profesyonel destek</p>
            <p class="m-0 mb-2"><span class="text-primary">✓</span> Şık mekanlar ve etkileyici dekorasyon çözümleri</p>
            <p class="m-0 mb-2"><span class="text-primary">✓</span> Geleneksel ve modern konseptlere uygun organizasyonlar</p>
            <p class="m-0 mb-2"><span class="text-primary">✓</span> Her çifte özel, tamamen kişiselleştirilmiş hizmet</p>
        </div>

        <div class="col-md-4 mt-5 aos-init aos-animate" data-aos="fade-left">
            <div>
                <img src="~/images/post-5.jpg" alt="Organizasyon" class="video-image img-fluid">
            </div>
        </div>

        <div class="col-md-4 mt-5 aos-init" data-aos="fade-right">
            <div class="section-title">
                <h3 class="mb-3 text-capitalize">Güvenilir ve Yaratıcı Organizasyon Hizmetleri</h3>
            </div>

            <p>
                Profesyonel ekibimiz; düğün, nişan, kına, söz ve özel davet organizasyonlarında estetik tasarımları,
                kusursuz planlaması ve kaliteli hizmet anlayışıyla fark yaratmaktadır.
            </p>

            <p>
                İster tüm organizasyon sürecini bize bırakın, ister yalnızca etkinlik günü koordinasyonu isteyin;
                deneyimli ekibimiz her ayrıntıyı sizin adınıza planlayarak unutulmaz bir gün yaşamanızı sağlar.
            </p>

            <ul>
                <li>Organizasyon süreci boyunca kişisel danışmanlık hizmeti</li>
                <li>Şık mekan ve konsept tasarımları</li>
                <li>Modern ve geleneksel organizasyon seçenekleri</li>
                <li>Kişiye özel tema ve dekorasyon hizmetleri</li>
                <li>Güvenilir iş ortakları ve sürekli destek</li>
            </ul>
        </div>

        <div class="col-md-4 mt-5 aos-init" data-aos="fade-up">
            <div>
                <img src="~/images/post-6.jpg" alt="Organizasyon" class="video-image img-fluid">
            </div>
        </div>

        <div class="col-md-4 mt-5 aos-init" data-aos="fade-left">
            <h3>Yaratıcı Vizyonumuz</h3>

            <p>
                Ever After Weddings olarak her çiftin hikayesini yansıtan, tamamen kişiye özel organizasyonlar
                tasarlıyoruz. Amacımız hayallerinizi gerçeğe dönüştüren unutulmaz anlar yaşatmaktır.
            </p>

            <p>
                Yılların verdiği deneyim ve yaratıcı bakış açımız sayesinde organizasyonun her aşamasında sizlere
                profesyonel rehberlik ediyor, tüm süreci keyifli ve stressiz hale getiriyoruz.
            </p>

            <p>
                Samimi aile kutlamalarından büyük düğün organizasyonlarına kadar her ölçekte etkinlik planlıyor,
                güvenilir iş ortaklarımızla kusursuz hizmet sunuyoruz. Hayaliniz ister sade ister gösterişli olsun,
                onu gerçeğe dönüştürmek için buradayız.
            </p>

            <a href="/User/ShopList" class="btn btn-outline-primary">Hizmetlerimizi İnceleyin</a>
        </div>
    </div>
</div>

<section id="categories" class="overflow-hidden">
    <div class="container-lg padding-medium">
        <div class="row" data-aos="fade-up">
            <div class="col-md-3 my-3">
                <div class="text-center">
                    <iconify-icon icon="solar:star-linear" class="service-icon text-primary display-3"></iconify-icon>
                    <h3 class="py-2">10+ Yıllık Deneyim</h3>
                    <p class="blog-paragraph">
                        Uzmanlık ve tutkuyla hayalinizdeki organizasyonları gerçeğe dönüştürüyoruz.
                    </p>
                </div>
            </div>

            <div class="col-md-3 my-3">
                <div class="text-center">
                    <iconify-icon class="service-icon text-primary display-3" icon="ph:plant-light"></iconify-icon>
                    <h3 class="py-2">Çevre Dostu Organizasyonlar</h3>
                    <p class="blog-paragraph">
                        Doğaya duyarlı, sürdürülebilir ve çevreci organizasyon çözümleri sunuyoruz.
                    </p>
                </div>
            </div>

            <div class="col-md-3 my-3">
                <div class="text-center">
                    <iconify-icon class="service-icon text-primary display-3"
                                  icon="solar:chat-square-like-broken"></iconify-icon>
                    <h3 class="py-2">5000+ Mutlu Çift</h3>
                    <p class="blog-paragraph">
                        Binlerce çift, kusursuz ve stressiz organizasyon deneyimi için bizi tercih etti.
                    </p>
                </div>
            </div>

            <div class="col-md-3 my-3">
                <div class="text-center">
                    <iconify-icon class="service-icon text-primary display-3"
                                  icon="fluent:people-team-28-regular"></iconify-icon>
                    <h3 class="py-2">28 Kişilik Uzman Ekip</h3>
                    <p class="blog-paragraph">
                        Tasarım, planlama ve organizasyon alanlarında deneyimli profesyonel kadromuzla hizmet veriyoruz.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>